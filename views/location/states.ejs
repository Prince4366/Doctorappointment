<h2>Select State</h2>

<div class="state-container">
  <% if (states.length === 0) { %>
    <p>No states available.</p>
  <% } %>

  <% states.forEach(state => { %>
    <a href="/doctors/states/<%= encodeURIComponent(state) %>" class="state-btn">
      <%= state %>
    </a>
  <% }) %>
</div>

<style>
.state-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 15px;
}

.state-btn {
  padding: 10px 15px;
  background: #198754;
  color: white;
  text-decoration: none;
  border-radius: 8px;
  transition: 0.2s;
}

.state-btn:hover {
  background: #157347;
}
</style>

