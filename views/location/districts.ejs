<h2>Districts in <%= state %></h2>

<div class="district-container">
  <% if (districts.length === 0) { %>
    <p>No districts found.</p>
  <% } %>

  <% districts.forEach(d => { %>
    <a href="/doctors/states/<%= encodeURIComponent(state) %>/<%= encodeURIComponent(d) %>" 
       class="district-btn">
       <%= d %>
    </a>
  <% }) %>
</div>

<style>
.district-container {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 15px;
}

.district-btn {
  padding: 10px 15px;
  background: #0d6efd;
  color: white;
  text-decoration: none;
  border-radius: 8px;
  transition: 0.2s;
}

.district-btn:hover {
  background: #0b5ed7;
}
</style>
