<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Patient Signup | PrimeCare</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
  <div class="pc-shell">
    <main class="container" style="max-width:620px;">
      <div class="pc-card" style="margin-top:18px;">
        <div class="pc-card-body">
          <h2 style="margin:0;">Create account</h2>
          <div style="color:var(--pc-muted); font-weight:600; margin-top:6px;">Register as a patient on PrimeCare.</div>

          <form method="POST" action="/auth/signup" style="margin-top:14px;">
            <div class="pc-grid" style="grid-template-columns: repeat(2, minmax(0, 1fr)); gap:10px;">
              <div>
                <label style="display:block; font-size:13px; font-weight:700; margin-bottom:6px;">Patient name</label>
                <input class="pc-input" name="name" placeholder="Full name" required>
              </div>

              <div>
                <label style="display:block; font-size:13px; font-weight:700; margin-bottom:6px;">Aadhar number</label>
                <input class="pc-input" name="aadhar" maxlength="12" placeholder="12-digit Aadhar" required>
              </div>

              <div>
                <label style="display:block; font-size:13px; font-weight:700; margin-bottom:6px;">Age</label>
                <input class="pc-input" name="age" type="number" placeholder="Age" required>
              </div>

              <div>
                <label style="display:block; font-size:13px; font-weight:700; margin-bottom:6px;">Mobile number</label>
                <input class="pc-input" name="mobile" placeholder="Mobile number" required>
              </div>

              <div style="grid-column: 1 / -1;">
                <label style="display:block; font-size:13px; font-weight:700; margin-bottom:6px;">Email</label>
                <input class="pc-input" name="email" type="email" placeholder="Email address" required>
              </div>

              <div style="grid-column: 1 / -1;">
                <label style="display:block; font-size:13px; font-weight:700; margin-bottom:6px;">Address</label>
                <textarea class="pc-input" name="address" placeholder="Full address" required style="min-height:90px; resize:vertical;"></textarea>
              </div>

              <div style="grid-column: 1 / -1;">
                <label style="display:block; font-size:13px; font-weight:700; margin-bottom:6px;">Password</label>
                <input class="pc-input" name="password" type="password" placeholder="Create a password" required>
              </div>
            </div>

            <button type="submit" class="pc-btn pc-btn-primary" style="width:100%; margin-top:12px;">Register</button>
          </form>

          <div style="margin-top:14px; color:var(--pc-muted); font-weight:600;">
            Already registered? <a class="pc-link" href="/auth/login">Login</a>
          </div>
        </div>
      </div>
    </main>
  </div>

</body>
</html>
