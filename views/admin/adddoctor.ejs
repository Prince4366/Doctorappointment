<h2 class="text-2xl font-semibold mb-6">Add Doctor</h2>

<form action="/admin/add-doctor" method="POST" 
      class="bg-white p-6 rounded-xl shadow max-w-3xl">

  <div class="grid grid-cols-2 gap-4">

    <div>
      <label class="block mb-1">Doctor Name</label>
      <input name="name" required class="w-full border p-2 rounded-lg">
    </div>

    <div>
      <label class="block mb-1">Degree</label>
      <input name="degree" class="w-full border p-2 rounded-lg">
    </div>

    <div>
      <label class="block mb-1">Specialization</label>
      <select name="specialization" required class="w-full border p-2 rounded-lg">
        <option value="">Select</option>
        <option>Cardiologist</option>
        <option>Dentist</option>
        <option>Gynecologist</option>
        <option>Orthopedist</option>
        <option>Pediatrician</option>
        <option>Dermatologist</option>
        <option>Neurologist</option>
      </select>
    </div>

    <div>
      <label class="block mb-1">Experience</label>
      <input name="experience" type="number" class="w-full border p-2 rounded-lg">
    </div>

    <div>
      <label class="block mb-1">Consultation Fee</label>
      <input name="consultationFee" type="number" required class="w-full border p-2 rounded-lg">
    </div>

    <div>
      <label class="block mb-1">Daily Limit</label>
      <input name="dailyLimit" type="number" class="w-full border p-2 rounded-lg">
    </div>

    <div>
      <label class="block mb-1">State</label>
      <input name="state" required class="w-full border p-2 rounded-lg">
    </div>

    <div>
      <label class="block mb-1">District</label>
      <input name="district" required class="w-full border p-2 rounded-lg">
    </div>

    <div class="col-span-2">
      <label class="block mb-1">Clinic Address</label>
      <input name="clinicAddress" class="w-full border p-2 rounded-lg">
    </div>

    <div>
      <label class="block mb-1">Latitude</label>
      <input name="lat" required class="w-full border p-2 rounded-lg">
    </div>

    <div>
      <label class="block mb-1">Longitude</label>
      <input name="lng" required class="w-full border p-2 rounded-lg">
    </div>

    <div class="col-span-2">
      <label class="block mb-1">Image URL</label>
      <input name="imageUrl" class="w-full border p-2 rounded-lg">
    </div>

    <div class="col-span-2">
      <label class="block mb-1">About Doctor</label>
      <textarea name="about" rows="3" class="w-full border p-2 rounded-lg"></textarea>
    </div>

  </div>

  <button 
    type="submit"
    class="mt-6 bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700">
    Add Doctor
  </button>

</form>